# AIFREE Configuration
# Copy this file to config.env and customize for your setup.

# Your project/org name (shows in the launcher banner)
PROJECT_NAME=AIFREE

# Ollama host (change if running on a different machine)
OLLAMA_HOST=http://127.0.0.1:11434

# Default model (pick one that fits your VRAM)
#   12GB+ VRAM: deepseek-coder-v2:16b
#   6-8GB VRAM: deepseek-coder-v2:16b or codellama:7b
#   4GB or CPU: codellama:7b or tinyllama
MODEL=deepseek-coder-v2:16b

# Path to your system prompt (loaded via aider --read)
SYSTEM_PROMPT=system-prompt.md
